# ─────────────────────────────────────────────────────────────
#  GV-CoT — .gitignore
# ─────────────────────────────────────────────────────────────

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.ipynb_checkpoints/

# ─── Virtual environments ───
.venv/
venv/
env/
.env

# ─── Logs & temp ───
*.log
*.tmp
*.bak

# ─── OS / editor junk ───
.DS_Store
Thumbs.db
desktop.ini
*.swp
.idea/
.vscode/
.claude/

# ─────────────────────────────────────────────────────────────
#  Large data artifacts — regenerate with the pipeline scripts.
#  Excluded from git because they are big and reproducible.
#  Remove a line below if you DO want to commit that file.
# ─────────────────────────────────────────────────────────────

# Source datasets (re-download via data/load_datasets.py)
data/hotpotqa_train.json
data/musique_train.json

# Generated CoT chains (regenerate via data/stage0_*.py)
data/cot_chains.json
data/musique_cot_chains.json
data/musique_cot_checkpoint_*.json

# Built graphs — ~3.4 GB total (regenerate via graphs/build_*.py)
graphs/*.pkl

# ─────────────────────────────────────────────────────────────
#  Kept in git on purpose (do NOT ignore):
#    - models/gat_best.pt          (1 MB trained model — the deliverable)
#    - data/_st_cache/samples_*.json (needed by app.py at runtime)
#    - graph_template.html         (the 3D graph, loaded by app.py)
#    - results/**                  (all evaluation outputs)
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
#  Extras from GitHub Python template (not covered above)
# ─────────────────────────────────────────────────────────────

# ─── C extensions ───
*.so

# ─── Distribution / packaging ───
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg
MANIFEST
*.manifest
*.spec

# ─── Installer logs ───
pip-log.txt
pip-delete-this-directory.txt

# ─── Test / coverage ───
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ─── Translations ───
*.mo
*.pot

# ─── Jupyter / IPython ───
profile_default/
ipython_config.py

# ─── Type checkers ───
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ─── Cython ───
cython_debug/

# ─── Package manager artifacts ───
__pypackages__/
.pdm-python
.pdm-build/
.pixi
.ruff_cache/
.pypirc

# ─── Misc tool artifacts ───
tempCodeRunnerFile.py
.ropeproject
.spyderproject
.spyproject
.scrapy
/site
docs/_build/
.pybuilder/
target/
.abstra/
.streamlit/secrets.toml
